# Staging Environment Configuration
# This uses REAL API DATA for staging/testing
# Use this to test with production-like data and environment

NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_API_BASE_URL=https://staging-api.stellar-insured.com
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_APP_NAME=Stellar Insured (Staging)

# For Stellar network (testnet is fine for staging)
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_EXPLORER_URL=https://testnet.stellar.expert/

# With NEXT_PUBLIC_APP_ENV=staging, the DataService will:
# - Make real API calls to NEXT_PUBLIC_API_BASE_URL
# - NOT use mock data
# - Use testnet for Stellar operations
# - This allows testing with production-like behavior while using test data
