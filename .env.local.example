# Development Environment Configuration
# This uses MOCK DATA for development/testing
# DO NOT use this configuration in production!

NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_APP_NAME=Stellar Insured (Dev)

# For Stellar network
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_EXPLORER_URL=https://testnet.stellar.expert/

# Note: With NEXT_PUBLIC_APP_ENV=development, the DataService will automatically
# use mock data from src/data/mockData.ts instead of making real API calls.
