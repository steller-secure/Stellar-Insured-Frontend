# Production Environment Configuration
# This uses REAL API DATA for production
# Make sure all required API endpoints are available before deploying

NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_API_BASE_URL=https://api.stellar-insured.com
NEXT_PUBLIC_STELLAR_NETWORK=mainnet
NEXT_PUBLIC_APP_NAME=Stellar Insured

# For Stellar network (mainnet)
NEXT_PUBLIC_HORIZON_URL=https://horizon.stellar.org
NEXT_PUBLIC_EXPLORER_URL=https://stellar.expert/

# Important: With NEXT_PUBLIC_APP_ENV=production, the DataService will:
# - Make real API calls to NEXT_PUBLIC_API_BASE_URL
# - NOT use mock data
# - Ensure all backend API endpoints are operational:
#   - GET /api/policies
#   - GET /api/claims
#   - GET /api/policies/{id}
#   - GET /api/claims/{id}
